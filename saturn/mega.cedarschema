entity UserGroup in [UserGroup];
entity User in [UserGroup];

entity Repository = {
    "is_private": Bool,
    "admins": UserGroup,
    "maintainers": UserGroup,
    "readers": UserGroup,
};

entity ChangeList = {
    "repo": Repository,
};

entity Issue = {
    "repo": Repository,
};

action "deleteRepo", "viewRepo", "forkRepo", "pullRepo", "pushRepo" appliesTo {
    principal: [User],
    resource: [Repository],
};

action "createChangeList", "editChangeList", "deleteChangeList", "approveChangeList" appliesTo {
    principal: [User],
    resource: [Repository],
};

action "openIssue", "assignIssue", "deleteIssue", "editIssue" appliesTo {
    principal: [User],
    resource: [Repository],
};

action "addMaintainer", "addAdmin" appliesTo {
    principal: [User],
    resource: [Repository],
};
